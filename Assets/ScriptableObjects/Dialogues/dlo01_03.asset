%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_03
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: "E a\xED, como v\xE3o as coisas?\r\n"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: -7406008489756895684, guid: 865ed9c84b829d04a91be083ff30981a, type: 3}
  - text: "P\xE9ssimas, nunca estive pior."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 5141988116160616292, guid: 5b0bd42f0124ad445a7fa44139787621, type: 3}
  - text: "\xC9, estranho seria se estiv\xE9ssemos bem.\r\n"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: -7406008489756895684, guid: 865ed9c84b829d04a91be083ff30981a, type: 3}
  - text: "E o Sacerdote deve t\xE1 te pressionando sobre a nomea\xE7\xE3o, acertei?"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "Eu n\xE3o desisti do meu pai."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
  - text: "\xC9, mas ele n\xE3o liga pra isso n\xE3o, o importante s\xE3o os recursos
      que \u201CO Ca\xE7ador\u201D consegue pra vila."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 2820870895528101754, guid: a7abecda11450354ca9b55f4b2b61e05, type: 3}
  - text: "Bem, eu at\xE9 entendo ele, mas se eu me nomear como o pr\xF3ximo ca\xE7ador,
      quer dizer que estou enterrando meu pai."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 5141988116160616292, guid: 5b0bd42f0124ad445a7fa44139787621, type: 3}
  - text: "Faz o que voc\xEA quiser, garoto, n\xE3o deixa ningu\xE9m tirar seu controle
      sobre sua pr\xF3pria vida."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: -7406008489756895684, guid: 865ed9c84b829d04a91be083ff30981a, type: 3}
  - text: "Seu destino s\xF3 pertence a voc\xEA."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: -7406008489756895684, guid: 865ed9c84b829d04a91be083ff30981a, type: 3}
  - text: "Esse \xE9 um bom conselho, Costureiro, obrigado."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
  - text: "Qual \xE9! S\xF3 fa\xE7o minha parte, se eu n\xE3o te ajudar sua m\xE3e
      volta pra me dar uns cascudos!"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "Me pergunto como ela era\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 5141988116160616292, guid: 5b0bd42f0124ad445a7fa44139787621, type: 3}
