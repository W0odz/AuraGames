MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dln01_01
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: "N\xE3o peguei no sono outra vez... j\xE1 \xE9 de manh\xE3."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: Ele sumiu tem... 3 dias?
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "J\xE1 s\xE3o 3 dias que eu n\xE3o durmo..."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "N\xE3o d\xE1 pra continuar assim."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "Pra come\xE7ar, eu tenho que falar com ele de novo, n\xE3o d\xE1 pra ficar
      evitando essa conversa."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
