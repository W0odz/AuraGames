--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_01
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  nodes:
  - text: "Desconfie do clar\xE3o repentino que vem da sombra."
    speakerSide: 1
    speakerName: Desgarrado
    portrait: {fileID: 1152047965712221352, guid: 7d5e095b02fa99347b65448d84e1876b, type: 3}
  - text: Como? O que isso significa?
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "Encapuzados. Encapuzados levam alde\xF5es para a floresta."
    speakerSide: 1
    speakerName: Desgarrado
    portrait: {fileID: 1152047965712221352, guid: 7d5e095b02fa99347b65448d84e1876b, type: 3}
  - text: "N\xE3o entendo por que n\xE3o levam a n\xF3s, os que s\xE3o descart\xE1veis."
    speakerSide: 1
    speakerName: Desgarrado
    portrait: {fileID: 1152047965712221352, guid: 7d5e095b02fa99347b65448d84e1876b, type: 3}
  - text: "\u2026Talvez isso n\xE3o importe para quem quer que esteja por tr\xE1s
      disso."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "Cuidado menino, \xE0s vezes o que buscamos se torna nossa ru\xEDna."
    speakerSide: 1
    speakerName: Desgarrado
    portrait: {fileID: 1152047965712221352, guid: 7d5e095b02fa99347b65448d84e1876b, type: 3}
