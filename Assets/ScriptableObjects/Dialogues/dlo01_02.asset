%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_02
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: Bom dia!
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: Bom dia, Herbalista.
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
  - text: "Impressionante como seu pai j\xE1 est\xE1 fazendo falta por aqui."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: " A essa hora, ele j\xE1 estaria aqui me chamando para assistir o serm\xE3o
      ou ent\xE3o pedindo algumas das minhas ervas e perguntando quais servem de
      tempero. Hahaha!"
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Eu tamb\xE9m estou sentindo muita falta\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 5141988116160616292, guid: 5b0bd42f0124ad445a7fa44139787621, type: 3}
  - text: " Se eu fosse voc\xEA n\xE3o me preocuparia tanto, pelo menos no caso dele,
      acho muito dif\xEDcil que ele n\xE3o consiga derrotar alguns bandidos."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: Sabe de uma coisa?
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: "O Ca\xE7ador \xE9 um dos homens mais gentis que eu j\xE1 conheci."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Ele nunca me culpou por ter falhado com a sua fam\xEDlia, pelo contr\xE1rio,
      ele fazia quest\xE3o de me dizer que eu n\xE3o tinha culpa e que o herbalista
      n\xE3o pode salvar a todos."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: "Nesse sentido ele tem toda raz\xE3o, voc\xEA n\xE3o pode se culpar por
      coisas que fogem do seu controle."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
  - text: Eu sei, estou melhorando isso.
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Mas esse conselho tamb\xE9m serve para voc\xEA, viu?"
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Seu pai \xE9 meu melhor amigo, se tem algu\xE9m que eu conhe\xE7o bem,
      \xE9 ele."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: Tenho certeza que ele vai superar qualquer desafio.
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: Estou contando com isso.
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
