%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: Dialogo_Costureiro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  nodes:
  - text: "E a\xED, como v\xE3o as coisas?\r\n"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "P\xE9ssimas, nunca estive pior."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "\xC9, estranho seria se estiv\xE9ssemos bem.\r\n"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "E o Sacerdote deve t\xE1 te pressionando sobre a nomea\xE7\xE3o, acertei?"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "Eu n\xE3o desisti do meu pai."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "\xC9, mas ele n\xE3o liga pra isso n\xE3o, o importante s\xE3o os recursos
      que \u201CO Ca\xE7ador\u201D consegue pra vila."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "Bem, eu at\xE9 entendo ele, mas se eu me nomear como o pr\xF3ximo ca\xE7ador,
      quer dizer que estou enterrando meu pai."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "Faz o que voc\xEA quiser, garoto, n\xE3o deixa ningu\xE9m tirar seu controle
      sobre sua pr\xF3pria vida."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "Seu destino s\xF3 pertence a voc\xEA."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "Esse \xE9 um bom conselho, Costureiro, obrigado."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
  - text: "Qual \xE9! S\xF3 fa\xE7o minha parte, se eu n\xE3o te ajudar sua m\xE3e
      volta pra me dar uns cascudos!"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 4271663865507447742, guid: bab1b369da905a04dbec28cee39ad1b2, type: 3}
  - text: "Me pergunto como ela era\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8487161343576945413, guid: 0aee62466e043724cbc9e8e41eec8b88, type: 3}
