  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_05
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: "E a\xED? O que achou da nossa base secreta?"
    speakerSide: 1
    speakerName: "A\xE7ougueiro"
    portrait: {fileID: 322978210323480407, guid: 4f4212e6a98b64d4c992fa4a772d9593, type: 3}
  - text: "Isso \xE9 insano! Como voc\xEAs arrumaram isso aqui tudo?"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
  - text: A gente tem as nossas manhas. Huhaha!
    speakerSide: 1
    speakerName: "A\xE7ougueiro"
    portrait: {fileID: 322978210323480407, guid: 4f4212e6a98b64d4c992fa4a772d9593, type: 3}
  - text: "Ent\xE3o voc\xEA \xE9 o cara das armas?"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
  - text: "\xC9 isso a\xED!"
    speakerSide: 1
    speakerName: "A\xE7ougueiro"
    portrait: {fileID: 322978210323480407, guid: 4f4212e6a98b64d4c992fa4a772d9593, type: 3}
  - text: "Se voc\xEA quiser qualquer tipo de arma \xE9 comigo que voc\xEA vai arrumar!"
    speakerSide: 1
    speakerName: "A\xE7ougueiro"
    portrait: {fileID: 322978210323480407, guid: 4f4212e6a98b64d4c992fa4a772d9593, type: 3}
  - text: "Mas e a\xED? Tem coisa boa pra trocar?"
    speakerSide: 1
    speakerName: "A\xE7ougueiro"
    portrait: {fileID: 322978210323480407, guid: 4f4212e6a98b64d4c992fa4a772d9593, type: 3}
  - text: "Vamos ver o que eu tenho aqui\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
