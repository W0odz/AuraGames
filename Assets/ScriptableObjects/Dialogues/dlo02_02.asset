  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo02_02
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 6164471941587510858, guid: 00beea1be0b85b54ab35f60f4dc0ad96, type: 3}
  nodes:
  - text: Garoto sem nome.
    speakerSide: 1
    speakerName: Parteira
    portrait: {fileID: 0}
  - text: "Voc\xEA deveria ser mais carinhosa, Parteira."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 2501241743405731456, guid: cb18f4aa16182e0449c5add5c7e4728e, type: 3}
  - text: Olha como fala com uma serva do Sacerdote.
    speakerSide: 1
    speakerName: Parteira
    portrait: {fileID: 0}
  - text: "Assim como todos n\xF3s aqui."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
  - text: "Voc\xEA se movimenta muito por a\xED e nada da sua nomea\xE7\xE3o."
    speakerSide: 1
    speakerName: Parteira
    portrait: {fileID: 0}
  - text: O que anda fazendo?
    speakerSide: 1
    speakerName: Parteira
    portrait: {fileID: 0}
  - text: "Isso n\xE3o te diz respeito."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
  - text: "Voc\xEA \xE9 ego\xEDsta, moleque, vai se tornar um Desgarrado e levar
      o vilarejo todo com voc\xEA."
    speakerSide: 1
    speakerName: Parteira
    portrait: {fileID: 0}
  - text: "Se voc\xEA n\xE3o acredita que o Fulgor pode trazer meu pai de volta,
      o problema n\xE3o est\xE1 em mim\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 2501241743405731456, guid: cb18f4aa16182e0449c5add5c7e4728e, type: 3}
