--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_07
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: O que me diz? Ficou animado para investigar?
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: Mais do que nunca.
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 2501241743405731456, guid: cb18f4aa16182e0449c5add5c7e4728e, type: 3}
  - text: "Mas cuidado, n\xE3o quero ver ningu\xE9m se machucando sem necessidade."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "D\xEA uma olhada no que eu tenho, talvez algumas dessas po\xE7\xF5es sejam
      de seu interesse."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Tem raz\xE3o, aquele monstro quase me matou, eu ia conseguir vencer sozinho,
      mas fiquei bem ferido mesmo."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
  - text: Sozinho?
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: "Sei, com certeza\u2026"
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: -2056641894727074072, guid: 806988b8130f0fa4ea33e20a99414952, type: 3}
  - text: "Mas voc\xEA s\xF3 vai p\xF4r sua m\xE3ozinha nelas se trocar comigo!"
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Tudo bem, parece justo. Deixa eu ver o que eu tenho\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
