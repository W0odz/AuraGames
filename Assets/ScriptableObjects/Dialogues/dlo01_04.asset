  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_04
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 8504605903420090578, guid: 77a78a97ca620c648b37c30d709b6fd7, type: 3}
  nodes:
  - text: "Tadinho, como voc\xEA est\xE1?"
    speakerSide: 1
    speakerName: Florista
    portrait: {fileID: 0}
  - text: Vou melhorar, Florista, obrigado.
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
  - text: "N\xE3o podemos perder a f\xE9, o Fulgor h\xE1 de nos salvar."
    speakerSide: 1
    speakerName: Florista
    portrait: {fileID: 0}
  - text: "Somos todos t\xE3o altru\xEDstas e devotos\u2026"
    speakerSide: 1
    speakerName: Florista
    portrait: {fileID: 0}
  - text: "Tamb\xE9m acredito nisso, me seguro muito nessa luz pra n\xE3o cair."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
  - text: "Sinto tanta falta do M\xFAsico, agora o Fazendeiro tamb\xE9m\u2026"
    speakerSide: 1
    speakerName: Florista
    portrait: {fileID: 0}
  - text: "Os Cultistas t\xEAm que achar eles."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -8774304836102649413, guid: 42c019abed3c7b44a8180c97944bf800, type: 3}
