%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlp02_02
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: "Mandou bem, moleque! Sabia que voc\xEA ia surpreender."
    speakerSide: 1
    speakerName: "A\xE7ougueiro"
    portrait: {fileID: 322978210323480407, guid: 4f4212e6a98b64d4c992fa4a772d9593, type: 3}
  - text: "Quem sabe ele \xE9 o tal do \u201Cescolhido\", n\xE9 loiro?"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "\u2026J\xE1 falei que n\xE3o acredito mais nisso."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 475354748142868185, guid: d6055f48fc8e3024cb89376388d4ae88, type: 3}
  - text: "Foi muito bom, parab\xE9ns."
    speakerSide: 1
    speakerName: Herbalista
    portrait: {fileID: 7290825780368180307, guid: 286619ef55f02e3438a773d4a9f25c55, type: 3}
  - text: "Ok, ok, j\xE1 chega."
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: -2999815174450519269, guid: 9c3bd70cb784dfd4c8aaf2e8e07f08b5, type: 3}
  - text: "Parab\xE9ns, ca\xE7adorzinho, j\xE1 estou at\xE9 pensando em algo pra
      voc\xEA."
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 2791210452372573440, guid: a3335bb26b57e78438a4529e9e10e1a2, type: 3}
  - text: Como pode ver, ainda estamos nos ajeitando aqui na base.
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: -2999815174450519269, guid: 9c3bd70cb784dfd4c8aaf2e8e07f08b5, type: 3}
  - text: "Mas j\xE1 que voc\xEA quer tanto investigar, tenho uma tarefa pro \u201Cprod\xEDgio\u201D."
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 2791210452372573440, guid: a3335bb26b57e78438a4529e9e10e1a2, type: 3}
  - text: Estou pronto pra qualquer coisa.
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 2501241743405731456, guid: cb18f4aa16182e0449c5add5c7e4728e, type: 3}
  - text: "Acredito que n\xE3o tenha mais nenhum grande perigo naquele peda\xE7o
      da floresta j\xE1 que matamos aquele monstro."
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 8070572476435812613, guid: 3d2db493b5e5ffa46877dfdebf579893, type: 3}
  - text: "Ent\xE3o sua miss\xE3o \xE9 a seguinte:"
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 8070572476435812613, guid: 3d2db493b5e5ffa46877dfdebf579893, type: 3}
  - text: "Volte para a mata e investigue aqueles casebres, al\xE9m daquele que voc\xEA
      encontrou, acredito ter visto outro."
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 8070572476435812613, guid: 3d2db493b5e5ffa46877dfdebf579893, type: 3}
  - text: Caso encontre algo relevante, volte pra me contar.
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 8070572476435812613, guid: 3d2db493b5e5ffa46877dfdebf579893, type: 3}
  - text: Entendido?
    speakerSide: 1
    speakerName: Carpinteira
    portrait: {fileID: 8070572476435812613, guid: 3d2db493b5e5ffa46877dfdebf579893, type: 3}
  - text: Sim, deixa comigo.
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
