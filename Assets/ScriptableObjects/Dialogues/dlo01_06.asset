%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 998d816f9ecd779408036895027b9b91, type: 3}
  m_Name: dlo01_06
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: O que achou do nosso esconderijo rebelde?
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "T\xF4 interessado nessas roupas diferentes que voc\xEA tem."
    speakerSide: 0
    speakerName: 
    portrait: {fileID: 2501241743405731456, guid: cb18f4aa16182e0449c5add5c7e4728e, type: 3}
  - text: "Foi ideia da sua m\xE3e, inclusive."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "Ela sempre temeu que um dia ir\xEDamos precisar nos armar."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "S\xE3o feitas de couro, ainda n\xE3o \xE9 meu projeto ideal mas t\xF4
      trabalhando nisso."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "Sempre desconfiado, n\xE9?"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
  - text: "Eu era um \u201CDesgarrado\u201D, garoto, eu nasci revoltado."
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "Mas e a\xED, vai querer ou n\xE3o?"
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: Quero trocar!
    speakerSide: 1
    speakerName: Costureiro
    portrait: {fileID: 3788498874315927691, guid: 7b96cea6e554bb34c89f656dcf0e3211, type: 3}
  - text: "T\xE1 certo, vamos ver o que eu tenho\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -2499865093323967227, guid: e2f5fa213065c3a499ebfc9317f46ac3, type: 3}
