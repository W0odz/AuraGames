  portraitEsquerda: {fileID: 0}
  portraitDireita: {fileID: 0}
  nodes:
  - text: "O Sacerdote nos diz pra nunca passar daqui\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -4293909199066766194, guid: a84e9df47cf59a74088a3d669648b720, type: 3}
  - text: "\xC9 realmente perigoso, eu s\xF3 vi uns animais grandes mas as lendas
      dizem\u2026"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -4293909199066766194, guid: a84e9df47cf59a74088a3d669648b720, type: 3}
  - text: "Mas... eu n\xE3o tenho escolha... o meu pai pode\u2014"
    speakerSide: 0
    speakerName: 
    portrait: {fileID: -4293909199066766194, guid: a84e9df47cf59a74088a3d669648b720, type: 3}
